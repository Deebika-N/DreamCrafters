meta {
  name: AI Generate Study Plan
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/study-plans/generate
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "goal": "Master Full Stack Web Development with React and Node.js",
    "start_date": "2026-03-22",
    "end_date": "2026-06-22",
    "daily_hours": 3
  }
}
